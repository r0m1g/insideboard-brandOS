{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "InsideBoard AI Brand OS — design tokens (W3C Design Tokens Community Group format). 3-tier architecture: primitive → semantic → component. Source of truth for brandOS-tokens.css. See ADR-002.",

  "primitive": {
    "$description": "Raw values — no references. The ground truth that everything else builds from.",

    "color": {
      "$description": "Color primitives — primary palette, warm gray scale, IRON agent reserved colors, functional palette.",

      "white":     { "$type": "color", "$value": "#FFFFFF", "$description": "Pure white." },
      "ivory":     { "$type": "color", "$value": "#FAFAF9", "$description": "Default canvas background (warm off-white)." },
      "gray-50":   { "$type": "color", "$value": "#F4EFE6" },
      "stone":     { "$type": "color", "$value": "#EAE6DF", "$description": "Surface tint — cards, dividers." },
      "ink":       { "$type": "color", "$value": "#1B1712", "$description": "Primary text and dark surfaces. Equals gray-900." },
      "ember":     { "$type": "color", "$value": "#EE2E20", "$description": "Brand accent — InsideBoard signature red." },

      "gray-100":  { "$type": "color", "$value": "#EAE3D6" },
      "gray-200":  { "$type": "color", "$value": "#DDD4C4" },
      "gray-300":  { "$type": "color", "$value": "#C9BEAB" },
      "gray-400":  { "$type": "color", "$value": "#AFA38E" },
      "gray-500":  { "$type": "color", "$value": "#8F8472" },
      "gray-600":  { "$type": "color", "$value": "#6F6656" },
      "gray-700":  { "$type": "color", "$value": "#4F483C" },
      "gray-800":  { "$type": "color", "$value": "#332E26" },
      "gray-900":  { "$type": "color", "$value": "#1B1712" },
      "gray-950":  { "$type": "color", "$value": "#0D0B08" },

      "fn-coral":    { "$type": "color", "$value": "#F08B73", "$description": "IRON agent — reserved, do not use outside agent contexts." },
      "fn-blue":     { "$type": "color", "$value": "#7DA8E8", "$description": "IRON agent — reserved, do not use outside agent contexts." },
      "fn-sage":     { "$type": "color", "$value": "#B8D29C", "$description": "IRON agent — reserved, do not use outside agent contexts." },
      "fn-lavender": { "$type": "color", "$value": "#B79BE8", "$description": "IRON agent — reserved, do not use outside agent contexts." },

      "fn-red":    { "$type": "color", "$value": "#C94040" },
      "fn-brick":  { "$type": "color", "$value": "#D4725A" },
      "fn-amber":  { "$type": "color", "$value": "#C8882A" },
      "fn-ochre":  { "$type": "color", "$value": "#B8963E" },
      "fn-moss":   { "$type": "color", "$value": "#6B8F5A" },
      "fn-pine":   { "$type": "color", "$value": "#3D7A62" },
      "fn-teal":   { "$type": "color", "$value": "#2E7A82" },
      "fn-steel":  { "$type": "color", "$value": "#4A7FBF" },
      "fn-slate":  { "$type": "color", "$value": "#4A5F8A" },
      "fn-plum":   { "$type": "color", "$value": "#7A5A8F" },
      "fn-mauve":  { "$type": "color", "$value": "#9E6B82" },
      "fn-brown":  { "$type": "color", "$value": "#7A4F35" }
    },

    "spacing": {
      "$description": "Linear spacing scale — 4 / 8 / 16 / 24 / 32 / 48 / 64 / 96 / 128 px.",
      "s1": { "$type": "dimension", "$value": "4px" },
      "s2": { "$type": "dimension", "$value": "8px" },
      "s3": { "$type": "dimension", "$value": "16px" },
      "s4": { "$type": "dimension", "$value": "24px" },
      "s5": { "$type": "dimension", "$value": "32px" },
      "s6": { "$type": "dimension", "$value": "48px" },
      "s7": { "$type": "dimension", "$value": "64px" },
      "s8": { "$type": "dimension", "$value": "96px" },
      "s9": { "$type": "dimension", "$value": "128px" }
    },

    "font": {
      "$description": "Font family stacks. @font-face declarations are not tokens — they remain in the generated CSS header.",
      "sans": { "$type": "fontFamily", "$value": ["Outfit", "Helvetica Neue", "Arial", "sans-serif"], "$description": "Body and display." },
      "mono": { "$type": "fontFamily", "$value": ["JetBrains Mono", "ui-monospace", "monospace"], "$description": "Section numbers, tags, code." }
    }
  },

  "semantic": {
    "$description": "Intent-based aliases — reference primitives by name, expressing where and why a value is used.",

    "color": {
      "$description": "Semantic color assignments.",
      "bg-canvas":            { "$type": "color", "$value": "{primitive.color.ivory}",  "$description": "Page canvas background." },
      "bg-paper":             { "$type": "color", "$value": "{primitive.color.white}",  "$description": "Elevated surfaces — cards, panels." },
      "bg-surface":           { "$type": "color", "$value": "{primitive.color.stone}",  "$description": "Tinted surface — wells, dividers." },
      "text-primary":         { "$type": "color", "$value": "{primitive.color.ink}",    "$description": "Default body text on light backgrounds." },
      "text-primary-inverse": { "$type": "color", "$value": "{primitive.color.ivory}",  "$description": "Body text on dark backgrounds." },
      "text-muted":           { "$type": "color", "$value": "rgba(250, 250, 249, 0.55)", "$description": "Muted text on dark backgrounds — ivory at 55% opacity." },
      "text-on-color":        { "$type": "color", "$value": "{primitive.color.ivory}",  "$description": "Text on Ember and other branded color fills." }
    },

    "density": {
      "$description": "Density multiplier. The generator emits the default in :root and the others under [data-density='<key>'] selectors.",
      "default":     { "$type": "number", "$value": 1 },
      "comfortable": { "$type": "number", "$value": 1.15 },
      "compact":     { "$type": "number", "$value": 0.85 }
    }
  },

  "component": {
    "$description": "Component-scoped tokens — express the role of primitives and semantics within specific UI components. Emitted as CSS custom properties ready for adoption in brandOS-components.css.",

    "nav": {
      "$description": "Sidebar navigation.",
      "nav-bg":     { "$type": "color", "$value": "{primitive.color.white}",    "$description": "Nav sidebar background." },
      "nav-border": { "$type": "color", "$value": "{primitive.color.gray-200}", "$description": "Nav right border and layer-link borders." },
      "nav-accent": { "$type": "color", "$value": "{primitive.color.ember}",    "$description": "Active state — group bar, link underline, counter." }
    },

    "hero": {
      "$description": "Hero section.",
      "hero-accent": { "$type": "color", "$value": "{primitive.color.ember}",    "$description": "Dot and badge active accent." },
      "hero-lede":   { "$type": "color", "$value": "{primitive.color.gray-600}", "$description": "Lede / subtitle text." },
      "hero-border": { "$type": "color", "$value": "{primitive.color.gray-200}", "$description": "Lower block top border." }
    },

    "chapter": {
      "$description": "Chapter / section container.",
      "chapter-accent":    { "$type": "color", "$value": "{primitive.color.ember}",    "$description": "Section number (.cn) and principle highlight." },
      "chapter-principle": { "$type": "color", "$value": "{primitive.color.gray-600}", "$description": "Principle paragraph (.pr) text." }
    },

    "callout": {
      "$description": "Callout box.",
      "callout-border":      { "$type": "color", "$value": "{primitive.color.gray-300}", "$description": "Default left border." },
      "callout-border-warn": { "$type": "color", "$value": "{primitive.color.ember}",    "$description": ".callout.warn left border." }
    },

    "formula": {
      "$description": "Formula dark block (.fd).",
      "formula-bg":   { "$type": "color", "$value": "{primitive.color.ink}",              "$description": "Dark background." },
      "formula-text": { "$type": "color", "$value": "{semantic.color.text-primary-inverse}", "$description": "Text on dark background." }
    }
  }
}
